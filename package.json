{
  "name": "armario-virtual-api",
  "version": "1.0.0",
  "description": "Virtual wardrobe API with AI capabilities",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "tsc && cd frontend && npm run build",
    "start": "NODE_ENV=production node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@gradio/client": "^2.2.1",
    "@imgly/background-removal-node": "^1.4.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.4",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.52.7",
    "replicate": "^0.32.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
